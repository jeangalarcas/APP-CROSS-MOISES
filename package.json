{
  "name": "boxos-app",
  "version": "1.0.0",
  "description": "Sistema completo de gestão para boxes de academia - Painel Admin + App Aluno + API",
  "private": true,
  "workspaces": [
    "backend",
    "admin",
    "aluno"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm -F backend dev\" \"pnpm -F admin dev\" \"pnpm -F aluno dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "db:migrate": "pnpm -F backend db:migrate",
    "db:seed": "pnpm -F backend db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
